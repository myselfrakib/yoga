rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow anyone to read files (course images, gallery, testimonials, site config)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Only allow authenticated users (like signed-in admins) to upload assets
    match /gallery/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    match /testimonials/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    match /course_images/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    match /course_demos/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    match /course_lessons/{allPaths=**} {
      allow write: if request.auth != null;
    }
    
    match /site_config/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
